# Email Marketing Operation — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to source control.

# ---------------------------------------------------------------------------
# Microsoft Graph API Credentials
# ---------------------------------------------------------------------------
# Required for reading the campaign request mailbox.
# Get these from your Microsoft Entra ID (Azure AD) app registration.

GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
GRAPH_ACCESS_TOKEN=your-access-token

# ---------------------------------------------------------------------------
# Charter Runtime API Key
# ---------------------------------------------------------------------------
# Required for campaign charter evaluation (OpenAI / Codex API).
# This key is resolved by the Narada charter runtime.

NARADA_MARKETING_CHARTER_API_KEY=sk-your-openai-key
# Alternative env var name also accepted:
# OPENAI_API_KEY=sk-your-openai-key

# ---------------------------------------------------------------------------
# Klaviyo API Credentials (v1 only — NOT used in dry run)
# ---------------------------------------------------------------------------
# These are reserved for future Klaviyo integration.
# Leave empty for the v0 dry run.

KLAVIYO_API_KEY=

# ---------------------------------------------------------------------------
# Windows Site Credential Override (optional)
# ---------------------------------------------------------------------------
# If running on Windows native, these override Credential Manager values.
# Format: NARADA_{SITE_ID}_{SECRET_NAME}

# NARADA_MARKETING_GRAPH_ACCESS_TOKEN=
# NARADA_MARKETING_GRAPH_TENANT_ID=
# NARADA_MARKETING_GRAPH_CLIENT_ID=
# NARADA_MARKETING_GRAPH_CLIENT_SECRET=
