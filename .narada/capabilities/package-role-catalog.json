{
  "schema": "narada.package_role_catalog.v0",
  "site_id": "narada-proper",
  "authority_source": ".narada/site.json",
  "purpose": "Classify Narada repo packages by authority role so package behavior is not inferred ad hoc from names, docs, or convenience.",
  "role_definitions": {
    "descriptor_contract": {
      "summary": "Reusable contracts, descriptors, plans, fixtures, and refusal guards. Does not own live mutation authority by package selection.",
      "default_denials": [
        "package_owned_sqlite_mutation",
        "native_shell_execution",
        "secret_or_credential_access",
        "source_site_runtime_state_import",
        "operator_surface_runtime_copying",
        "pc_locus_mutation"
      ]
    },
    "runtime_authority": {
      "summary": "Runtime/control-plane implementation package. May own persistence, credentials, adapters, or effect execution only through its declared authority model."
    },
    "cli_exposure": {
      "summary": "Command surface package. Exposes finite commands and governed operations; command availability is not itself authority to mutate outside declared loci."
    },
    "platform_template": {
      "summary": "Platform/Site template package. Produces plans and local setup descriptors; live setup remains separately admitted."
    },
    "mcp_boundary": {
      "summary": "MCP boundary, policy, supervisor, or test package. Describes or validates tool surfaces without granting unbounded shell/process authority."
    },
    "vertical": {
      "summary": "Domain vertical package traveling through the Narada kernel model."
    },
    "domain_model": {
      "summary": "Domain concepts, types, or charter model package."
    },
    "ops_fixture": {
      "summary": "Operational fixtures and examples. Fixture data is not Site authority or live customer state."
    }
  },
