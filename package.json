{
  "name": "narada",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "narada:install-shim": "bash scripts/install-narada-shim.sh",
    "narada:guard-task-db": "bash scripts/guard-task-lifecycle-db.sh",
    "narada:guard-cli-output": "node scripts/cli-output-admission-guard.mjs",
    "narada:guard-cli-output:report": "node scripts/cli-output-admission-guard.mjs --report",
    "narada:guard-process-launch-posture": "node scripts/process-launch-posture-guard.mjs",
    "narada:guard-process-launch-posture:report": "node scripts/process-launch-posture-guard.mjs --report",
    "site:continuity:loop": "node scripts/site-continuity-loop.mjs",
    "site:continuity:loop:test": "node --test scripts/site-continuity-loop.test.mjs",
    "cloudflare:operator:check": "node scripts/cloudflare-operator-check.mjs",
    "cloudflare:operator:check:human": "node scripts/cloudflare-operator-check.mjs --require-operator-session",
    "cloudflare:operator:check:human-action": "node scripts/cloudflare-operator-check.mjs --require-human-operator-action",
    "cloudflare:operator:check:test": "node --test scripts/cloudflare-operator-check.test.mjs",
    "cloudflare:product:readiness": "node scripts/cloudflare-product-readiness.mjs",
    "cloudflare:product:readiness:test": "node --test scripts/cloudflare-product-readiness.test.mjs",
    "cloudflare:operator:login": "node scripts/cloudflare-operator-login.mjs",
    "cloudflare:operator:site:bootstrap": "node scripts/cloudflare-operator-site-bootstrap.mjs",
    "cloudflare:operator:operation:bootstrap": "node scripts/cloudflare-operator-operation-bootstrap.mjs",
    "test": "tsx scripts/test-guard.ts",
    "verify": "node --import tsx scripts/verify.ts",
    "test:unit": "tsx scripts/test-unit.ts",
    "test:integration": "tsx scripts/test-integration.ts",
    "test:full": "tsx scripts/test-full.ts",
    "test:focused": "node scripts/test-focused.mjs",
    "agent-tui:test:focused": "pwsh -NoProfile -File tools/agent-tui/test-agent-tui.ps1",
    "agent-tui:test": "pwsh -NoProfile -File tools/agent-tui/test-agent-tui.ps1 -Full",
    "agent-tui:test:verbose": "pwsh -NoProfile -File tools/agent-tui/test-agent-tui.ps1 -Full -VerboseOutput",
    "agent-tui:test:wrapper": "node --test --test-reporter=dot tools/agent-tui/test-agent-tui.test.mjs",
    "agent-start:test": "node --test --test-reporter=dot tools/agent-start/start-agent.test.mjs",
    "agent-tui:live-turn-acceptance": "node tools/agent-start/agent-tui-live-turn-acceptance.mjs",
    "agent-tui:live-turn-acceptance:test": "node --test --test-reporter=dot tools/agent-start/agent-tui-live-turn-acceptance.test.mjs",
    "agent-start:test:verbose": "node --test tools/agent-start/start-agent.test.mjs",
    "test:control-plane": "pnpm --filter @narada2/control-plane test",
    "test:daemon": "pnpm --filter @narada2/daemon test",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "benchmark": "pnpm -r benchmark",
    "benchmark:compare": "tsx scripts/benchmark-compare.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "tsx scripts/publish-local.ts",
    "control-plane-lint": "tsx scripts/control-plane-lint.ts",
    "prepublish-check": "tsx scripts/prepublish-check.ts",
    "pack:check": "tsx scripts/prepublish-check.ts --pack-only",
    "toolchain:oxbuild-probe": "node scripts/oxbuild-probe.mjs"
  },
  "config": {
    "uscVersion": "^1.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@narada2/agent-cli": "workspace:*",
    "@narada2/agent-runtime-server": "workspace:*",
    "@narada2/agent-tui": "workspace:*",
    "@narada2/agent-web-ui": "workspace:*",
    "@narada2/cli": "workspace:*",
    "@types/node": "^22.0.0",
    "oxbuild": "^0.1.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
