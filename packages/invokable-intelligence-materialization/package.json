{
  "name": "@narada2/invokable-intelligence-materialization",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "narada": {
    "package_role": "portable_intelligence_materialization_storage",
    "surface": "invokable_intelligence",
    "presentation_only": false,
    "authority_owner": "@narada2/cli"
  },
  "exports": {
    "./d1": {
      "types": "./dist/d1-store.d.ts",
      "import": "./dist/d1-store.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@narada2/invokable-intelligence-contract": "workspace:*"
  },
  "devDependencies": {
    "@narada2/invokable-intelligence-registry": "workspace:*",
    "@types/node": "^22.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "description": "Portable node:sqlite and Cloudflare D1 embodiments of governed invokable intelligence",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/invokable-intelligence-materialization"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
