{
  "name": "@narada2/nars-session-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_session_core",
    "owns": [
      "session_lifecycle_state",
      "session_shutdown_state",
      "durable_event_journal",
      "event_sequence_and_replay",
      "artifact_registry",
      "artifact_lifecycle_state",
      "operator_input_queue_state",
      "input_admission_state",
      "session_health_and_recovery_snapshots",
      "turn_lifecycle_state",
      "session_registry_projection",
      "authority_transition_state",
      "authority_handoff_lifecycle_state",
      "recovery_attempt_state",
      "event_attachment_state"
    ],
    "does_not_own": [
      "provider_turn_execution",
      "mcp_transport_or_dispatch",
      "effect_admission",
      "external_effect_confirmation",
      "client_rendering"
    ]
  },
  "exports": {
    ".": "./src/index.mjs",
    "./event-log": "./src/event-log.mjs",
    "./event-hub": "./src/event-hub.mjs",
    "./event-attachment-state": "./src/event-attachment-state.mjs",
    "./session-lifecycle-state": "./src/session-lifecycle-state.mjs",
    "./session-shutdown-state": "./src/session-shutdown-state.mjs",
    "./artifact-lifecycle-state": "./src/artifact-lifecycle-state.mjs",
    "./artifacts": "./src/artifacts.mjs",
    "./input-queue": "./src/input-queue.mjs",
    "./input-admission-state": "./src/input-admission-state.mjs",
    "./operator-input-queue-state": "./src/operator-input-queue-state.mjs",
    "./session-status-snapshots": "./src/session-status-snapshots.mjs",
    "./session-index": {
      "types": "./src/session-index.d.ts",
      "default": "./src/session-index.mjs"
    },
    "./authority-transition-state": "./src/authority-transition-state.mjs",
    "./authority-transition-fsm": "./src/authority-transition-fsm.mjs",
    "./authority-handoff-fsm": "./src/authority-handoff-fsm.mjs",
    "./recovery-attempt-state": "./src/recovery-attempt-state.mjs",
    "./session-core": "./src/session-core.mjs",
    "./session-supervisor": "./src/session-supervisor.mjs",
    "./turn-state": "./src/turn-state.mjs",
    "./session-control-contract": "./src/session-control-contract.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/index.mjs src/event-log.mjs src/event-hub.mjs src/event-attachment-state.mjs src/session-lifecycle-state.mjs src/session-shutdown-state.mjs src/artifact-lifecycle-state.mjs src/artifacts.mjs src/input-queue.mjs src/input-admission-state.mjs src/operator-input-queue-state.mjs src/session-status-snapshots.mjs src/session-index.mjs src/authority-transition-fsm.mjs src/authority-handoff-fsm.mjs src/authority-transition-state.mjs src/recovery-attempt-state.mjs src/turn-state.mjs src/session-core.mjs src/session-supervisor.mjs src/session-control-contract.mjs"
  },
  "dependencies": {
    "@narada2/agent-identity": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/nars-runtime-contract": "workspace:*",
    "@narada2/site-paths": "workspace:*"
  },
  "description": "NARS session core"
}
