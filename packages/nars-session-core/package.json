{
  "name": "@narada2/nars-session-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_session_core",
    "owns": [
      "session_lifecycle_state",
      "durable_event_journal",
      "event_sequence_and_replay",
      "artifact_registry",
      "operator_input_queue_state",
      "session_health_and_recovery_snapshots",
      "session_registry_projection",
      "authority_transition_state"
    ],
    "does_not_own": [
      "provider_turn_execution",
      "mcp_transport_or_dispatch",
      "effect_admission",
      "external_effect_confirmation",
      "client_rendering"
    ]
  },
  "exports": {
    ".": "./src/index.mjs",
    "./event-log": "./src/event-log.mjs",
    "./event-hub": "./src/event-hub.mjs",
    "./artifacts": "./src/artifacts.mjs",
    "./input-queue": "./src/input-queue.mjs",
    "./operator-input-queue-state": "./src/operator-input-queue-state.mjs",
    "./session-status-snapshots": "./src/session-status-snapshots.mjs",
    "./session-index": "./src/session-index.mjs",
    "./authority-transition-state": "./src/authority-transition-state.mjs",
    "./session-core": "./src/session-core.mjs",
    "./session-supervisor": "./src/session-supervisor.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/index.mjs src/event-log.mjs src/event-hub.mjs src/artifacts.mjs src/input-queue.mjs src/operator-input-queue-state.mjs src/session-status-snapshots.mjs src/session-index.mjs src/authority-transition-state.mjs src/session-core.mjs src/session-supervisor.mjs"
  },
  "dependencies": {
    "@narada2/agent-identity": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/site-paths": "workspace:*"
  }
}
