{
  "name": "@narada2/carrier-terminal-projection",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_runtime_neutral_terminal_projection",
    "owns": [
      "terminal_event_projection",
      "operator_input_protocol_frame_projection"
    ],
    "does_not_own": [
      "provider_runtime",
      "mcp_fabric_hosting",
      "session_runtime_dispatch"
    ]
  },
  "exports": {
    ".": "./src/projected-terminal.mjs",
    "./projected-input": "./src/projected-input.mjs",
    "./projected-terminal": "./src/projected-terminal.mjs",
    "./terminal-event-rendering": "./src/terminal-event-rendering.mjs",
    "./terminal-markdown": "./src/terminal-markdown.mjs",
    "./terminal-style": "./src/terminal-style.mjs",
    "./terminal-text": "./src/terminal-text.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/projected-input.mjs src/projected-terminal.mjs src/terminal-event-rendering.mjs src/terminal-markdown.mjs src/terminal-style.mjs src/terminal-text.mjs"
  }
}
