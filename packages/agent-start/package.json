{
  "name": "@narada2/agent-start",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@narada2/agent-context-mcp": "workspace:*",
    "@narada2/agent-identity": "workspace:*",
    "@narada2/agent-runtime-server": "workspace:*",
    "@narada2/operator-surface-runtime-contract": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/carrier-provider-support": "workspace:*",
    "@narada2/carrier-provider-contract": "workspace:*",
    "@narada2/process-launch-posture": "workspace:*",
    "@narada2/nars-client-projection-contract": "workspace:*",
    "@narada2/site-paths": "workspace:*",
    "zod": "^3.22.0"
  },
  "bin": {
    "narada-agent-start": "./src/narada-agent-start.ts",
    "narada-agent-start-verify-launchers": "./bin/verify-registered-site-launchers.mjs"
  },
  "exports": {
    ".": "./src/narada-agent-start.ts",
    "./narada-agent-start": "./src/narada-agent-start.ts",
    "./launch-result-v0-contract": {
      "types": "./src/launch-result-v0-contract.d.mts",
      "import": "./src/launch-result-v0-contract.mjs"
    },
    "./verify-registered-site-launchers": "./bin/verify-registered-site-launchers.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "syntaxcheck": "node --import tsx --check src/narada-agent-start.ts && node --check bin/verify-registered-site-launchers.mjs",
    "generate:result-schema": "node --import tsx scripts/generate-result-schema.ts",
    "check:result-contract": "node --import tsx scripts/generate-result-schema.ts --check",
    "test": "node test/run-agent-start-tests.mjs",
    "test:launcher-contract": "node test/run-launcher-registry-contract-shards.mjs",
    "verify": "node bin/verify-registered-site-launchers.mjs",
    "test:option-contract": "node test/run-option-contract-shards.mjs"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "zod-to-json-schema": "^3.25.2"
  }
}
