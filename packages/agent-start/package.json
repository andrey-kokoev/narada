{
  "name": "@narada2/agent-start",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@narada2/agent-context-mcp": "workspace:*"
  },
  "bin": {
    "narada-agent-start": "./src/narada-agent-start.ts",
    "narada-agent-start-verify-launchers": "./bin/verify-registered-site-launchers.mjs"
  },
  "exports": {
    ".": "./src/narada-agent-start.ts",
    "./verify-registered-site-launchers": "./bin/verify-registered-site-launchers.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --import tsx src/narada-agent-start.ts narada.architect --site-root ../.. --target-site-root ../.. --runtime agent-cli --dry-run --json && node --check bin/verify-registered-site-launchers.mjs && node --test test/launcher-registry-contract.test.mjs test/option-contract.test.mjs",
    "test:launcher-contract": "node --test test/launcher-registry-contract.test.mjs",
    "verify": "node bin/verify-registered-site-launchers.mjs",
    "test:option-contract": "node --test test/option-contract.test.mjs"
  }
}
