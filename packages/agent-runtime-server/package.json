{
  "name": "@narada2/agent-runtime-server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "narada": {
    "package_role": "nars_runtime_server",
    "owns": [
      "server_request_handling",
      "server_request_lifecycle",
      "session_binding",
      "session_status_and_health_projection",
      "health_projection_request_lifecycle",
      "runtime_event_subscription",
      "runtime_lifecycle_hooks",
      "runtime_intelligence_reconfiguration",
      "artifact_http_request_handling",
      "attachment_contract",
      "carrier_substrate_handoff",
      "runtime_host_lifecycle"
    ],
    "carrier_substrate": "@narada2/carrier-runtime in-process",
    "runtime_dependency_owner": "nars-session-core owns session control and durability; nars-provider-runtime supplies provider execution"
  },
  "bin": {
    "narada-agent-runtime-server": "./bin/narada-agent-runtime-server.mjs"
  },
  "exports": {
    ".": "./src/server-wrapper.mjs",
    "./runtime-session-binding": "./src/runtime-session-binding.mjs",
    "./session-core-runtime-service": "./src/session-core-runtime-service.mjs",
    "./runtime-context": "./src/runtime-context.mjs",
    "./control-input-bridge": "./src/control-input-bridge.mjs",
    "./runtime-host-state": "./src/runtime-host-state.mjs",
    "./runtime-request-state": "./src/runtime-request-state.mjs",
    "./health-projection-request-state": "./src/health-projection-request-state.mjs",
    "./runtime-control-contract": "./src/runtime-control-contract.mjs",
    "./provider-runtime-reconfiguration-state": "./src/provider-runtime-reconfiguration-state.mjs",
    "./provider-runtime-controller": "./src/provider-runtime-controller.mjs",
    "./runtime-server-events": "./src/runtime-server-events.mjs",
    "./test-fixtures": "./src/test-fixtures.mjs",
    "./agent-cli-windows-wrapper-template": "./templates/Start-AgentCliSession.ps1",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false bin/narada-agent-runtime-server.mjs src/server-wrapper.mjs src/runtime-context.mjs src/control-input-bridge.mjs src/runtime-host-state.mjs src/runtime-request-state.mjs src/health-projection-request-state.mjs src/runtime-session-binding.mjs src/session-core-runtime-service.mjs src/runtime-server-events.mjs src/runtime-control-contract.mjs src/provider-runtime-reconfiguration-state.mjs src/provider-runtime-controller.mjs src/test-fixtures.mjs"
  },
  "dependencies": {
    "@narada2/agent-identity": "workspace:*",
    "@narada2/carrier-runtime": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/carrier-provider-contract": "workspace:*",
    "@narada2/carrier-terminal-projection": "workspace:*",
    "@narada2/launch-process-ownership": "workspace:*",
    "@narada2/nars-session-core": "workspace:*",
    "@narada2/nars-capability-gateway": "workspace:*",
    "@narada2/nars-provider-runtime": "workspace:*",
    "@narada2/process-launch-posture": "workspace:*",
    "@narada2/site-paths": "workspace:*"
  }
}
