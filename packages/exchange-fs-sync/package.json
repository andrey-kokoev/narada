{
  "name": "exchange-fs-sync",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "rolldown --config --watch",
    "build": "rolldown --config",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "pnpm typecheck && pnpm lint && pnpm fmt:check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "oxfmt": "^0.1.0",
    "oxlint": "^0.15.0",
    "rolldown": "^0.14.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
