{
  "name": "@narada2/local-history",
  "version": "0.1.0",
  "description": "Site-owned, VS Code-independent local work history",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "config.schema.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./daemon": {
      "types": "./dist/daemon-entry.d.ts",
      "import": "./dist/daemon-entry.js",
      "default": "./dist/daemon-entry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@narada2\/sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types\/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
