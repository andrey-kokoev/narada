{
  "name": "@narada2/nars-provider-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_provider_runtime",
    "owns": [
      "canonical_request_shaping",
      "canonical_provider_transport",
      "provider_process_lifecycle",
      "owned_process_state",
      "provider_invocation_lifecycle"
    ],
    "does_not_own": [
      "intelligence_selection",
      "catalog_policy",
      "session_persistence",
      "mcp_hosting",
      "control_protocol"
    ]
  },
  "exports": {
    ".": "./src/index.mjs",
    "./canonical-invocation-adapter": "./src/canonical-invocation-adapter.mjs",
    "./canonical-protocol-adapters": "./src/canonical-protocol-adapters.mjs",
    "./canonical-transports": "./src/canonical-transports.mjs",
    "./credential-locator": "./src/credential-locator.mjs",
    "./runtime-tail-utils": "./src/runtime-tail-utils.mjs",
    "./process-supervisor": "./src/process-supervisor.mjs",
    "./owned-process-state": "./src/owned-process-state.mjs",
    "./provider-invocation-state": "./src/provider-invocation-state.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/index.mjs src/canonical-invocation-adapter.mjs src/canonical-protocol-adapters.mjs src/canonical-transports.mjs src/credential-locator.mjs src/provider-invocation-state.mjs src/owned-process-state.mjs src/runtime-tail-utils.mjs src/process-supervisor.mjs"
  },
  "dependencies": {
    "@narada2/carrier-provider-support": "workspace:*",
    "@narada2/mcp-fabric": "workspace:*",
    "@narada2/process-launch-posture": "workspace:*"
  },
  "description": "NARS provider runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/nars-provider-runtime"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
