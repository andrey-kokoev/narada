{
  "name": "@narada2/workspace-launch-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "private_operator_surface_ui",
    "surface": "launcher_session_dashboard",
    "authority_owner": "@narada2/cli",
    "presentation_only": true,
    "launch_artifact": {
      "target": "workspace-launch",
      "build_script": "build",
      "output_root": "dist",
      "required_outputs": [
        "index.html",
        "assets/**"
      ]
    }
  },
  "exports": {
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @narada2/ui build",
    "build": "vite build",
    "postbuild": "node ../layers/cli/scripts/write-launch-artifact.mjs --target workspace-launch --package-root . --site-root ../..",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/domain.test.ts test/transport.test.ts test/architecture-boundary.test.ts"
  },
  "dependencies": {
    "@narada2/workspace-launch-contract": "workspace:*",
    "@narada2/ui-vue": "workspace:*",
    "lucide-vue-next": "^0.563.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.7",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.7.0",
    "vite": "^8.1.1",
    "vue-tsc": "^2.2.0"
  }
}
