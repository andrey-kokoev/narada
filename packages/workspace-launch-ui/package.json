{
  "name": "@narada2/workspace-launch-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "private_operator_surface_ui",
    "surface": "launcher_session_dashboard",
    "authority_owner": "@narada2/cli",
    "presentation_only": true
  },
  "exports": {
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @narada2/ui build",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@narada2/ui-vue": "workspace:*",
    "lucide-vue-next": "^0.563.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.7",
    "tailwindcss": "^4.1.18",
    "vite": "^8.1.1",
    "vue-tsc": "^2.2.0"
  }
}
