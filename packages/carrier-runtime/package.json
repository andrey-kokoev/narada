{
  "name": "@narada2/carrier-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_carrier_runtime_substrate",
    "owns": [
      "provider_runtime_adapters",
      "mcp_runtime_fabric",
      "carrier_server_mode",
      "carrier_substrate_support_modules"
    ]
  },
  "exports": {
    ".": "./src/index.mjs",
    "./carrier-runtime-context": "./src/carrier-runtime-context.mjs",
    "./provider-adapters": "./src/provider-adapters.mjs",
    "./provider-resolution": "./src/provider-resolution.mjs",
    "./mcp-runtime": "./src/mcp-runtime.mjs",
    "./server-mode": "./src/server-mode.mjs",
    "./input-queue": "./src/input-queue.mjs",
    "./runtime-dependencies": "./src/runtime-dependencies.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/index.mjs src/provider-adapters.mjs src/provider-resolution.mjs src/mcp-runtime.mjs src/server-mode.mjs src/input-queue.mjs src/runtime-dependencies.mjs src/carrier-runtime-context.mjs"
  },
  "dependencies": {
    "@narada2/carrier-action-admission": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/carrier-provider-contract": "workspace:*",
    "@narada2/carrier-provider-support": "workspace:*",
    "@narada2/mcp-fabric": "workspace:*",
    "@narada2/nars-client-projection-contract": "workspace:*"
  }
}
