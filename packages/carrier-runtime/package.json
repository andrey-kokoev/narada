{
  "name": "@narada2/carrier-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_carrier_turn_adapter",
    "owns": [
      "stateless_provider_turn_adapter",
      "legacy_runtime_compatibility_facades"
    ],
    "does_not_own": ["session_persistence", "mcp_hosting", "transport_supervision"]
  },
  "exports": {
    ".": "./src/index.mjs",
    "./carrier-runtime-context": "./src/carrier-runtime-context.mjs",
    "./provider-adapters": "./src/provider-adapters.mjs",
    "./provider-resolution": "./src/provider-resolution.mjs",
    "./provider-runtime-defaults": "./src/provider-runtime-defaults.mjs",
    "./carrier-turn-adapter": "./src/carrier-turn-adapter.mjs",
    "./mcp-runtime": "./src/mcp-runtime.mjs",
    "./process-supervisor": "./src/process-supervisor.mjs",
    "./server-mode": "./src/server-mode.mjs",
    "./input-queue": "./src/input-queue.mjs",
    "./runtime-dependencies": "./src/runtime-dependencies.mjs",
    "./nars-event-log": "./src/nars-event-log.mjs",
    "./nars-artifacts": "./src/nars-artifacts.mjs",
    "./nars-session-index": "./src/nars-session-index.mjs",
    "./authority-transition-state": {
      "types": "./src/authority-transition-state.d.ts",
      "default": "./src/authority-transition-state.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/index.mjs src/provider-adapters.mjs src/provider-resolution.mjs src/provider-runtime-defaults.mjs src/carrier-turn-adapter.mjs src/mcp-runtime.mjs src/process-supervisor.mjs src/server-mode.mjs src/input-queue.mjs src/runtime-dependencies.mjs src/carrier-runtime-context.mjs src/nars-event-log.mjs src/nars-artifacts.mjs src/nars-session-index.mjs src/operator-input-queue-state.mjs src/authority-transition-state.mjs"
  },
  "dependencies": {
    "@narada2/nars-runtime-legacy-compat": "workspace:*"
  }
}
