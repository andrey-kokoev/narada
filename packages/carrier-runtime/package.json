{
  "name": "@narada2/carrier-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_carrier_turn_adapter",
    "owns": [
      "stateless_intelligence_invocation_turn_adapter"
    ],
    "does_not_own": [
      "session_persistence",
      "mcp_hosting",
      "transport_supervision"
    ]
  },
  "exports": {
    ".": "./src/index.mjs",
    "./carrier-turn-adapter": "./src/carrier-turn-adapter.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/index.mjs src/carrier-turn-adapter.mjs"
  },
  "description": "NARS carrier runtime substrate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/carrier-runtime"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
