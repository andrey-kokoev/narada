    "smoke:live": "node scripts/cloudflare-nars-web-projection-live-smoke.mjs"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
