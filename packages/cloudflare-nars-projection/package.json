{
  "name": "@narada2/cloudflare-nars-projection",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prebuild:assets": "node scripts/clean-cloudflare-assets.mjs",
    "build:assets": "pnpm --filter @narada2/operator-console-ui build && pnpm --filter @narada2/agent-web-ui build && node scripts/build-cloudflare-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy:dry-run": "pnpm run build:assets && wrangler deploy --dry-run --config wrangler.toml",
    "deploy:live": "pnpm run build:assets && wrangler deploy --config wrangler.toml",
    "smoke:local-origin-live": "node scripts/cloudflare-nars-web-projection-live-smoke.mjs",
    "smoke:cloudflare-origin-live": "node scripts/cloudflare-nars-authority-live-smoke.mjs",
    "smoke:provider-capable-live": "node scripts/cloudflare-nars-provider-live-smoke.mjs",
    "smoke:live": "pnpm run smoke:local-origin-live",
    "smoke:authority-live": "pnpm run smoke:cloudflare-origin-live"
  },
  "dependencies": {
    "@narada2/nars-session-core": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/carrier-provider-contract": "workspace:*",
    "@narada2/nars-runtime-contract": "workspace:*",
    "@narada2/operator-console-contract": "workspace:*",
    "@narada2/process-launch-posture": "workspace:*",
    "@narada2/nars-client-projection-contract": "workspace:*",
    "@narada2/site-paths": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/cloudflare-nars-projection"
  }
}
