{
  "name": "@narada2/cloudflare-nars-projection",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy:dry-run": "wrangler deploy --dry-run --config wrangler.toml",
    "deploy:live": "pnpm --filter @narada2/agent-web-ui build && wrangler deploy --config wrangler.toml",
    "smoke:local-origin-live": "node scripts/cloudflare-nars-web-projection-live-smoke.mjs",
    "smoke:cloudflare-origin-live": "node scripts/cloudflare-nars-authority-live-smoke.mjs",
    "smoke:live": "pnpm run smoke:local-origin-live",
    "smoke:authority-live": "pnpm run smoke:cloudflare-origin-live"
  },
  "dependencies": {
    "@narada2/nars-client-projection-contract": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
