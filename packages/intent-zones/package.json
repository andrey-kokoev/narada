{
  "name": "@narada2/intent-zones",
  "version": "0.1.0",
  "description": "Narada Command Execution and Testing Intent Zone contracts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing-intent": {
      "types": "./dist/testing-intent.d.ts",
      "import": "./dist/testing-intent.js"
    },
    "./command-execution-intent": {
      "types": "./dist/command-execution-intent.d.ts",
      "import": "./dist/command-execution-intent.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
