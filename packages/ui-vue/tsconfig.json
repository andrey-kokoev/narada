{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "allowJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@narada2/ui-vue": ["src/index.ts"],
      "@narada2/ui-vue/styles.css": ["src/styles.css"],
      "@narada2/ui/styles.css": ["../ui/src/styles.css"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts", "test/fixture/**/*.ts", "test/fixture/**/*.vue", "test/env.d.ts"]
}
