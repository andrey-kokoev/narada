{
  "schema": "narada.carrier.provider_registry.v1",
  "description": "Authoritative provider metadata for carrier provider resolution, launcher projection, docs, and drift tests.",
  "default_provider": "kimi-code-api",
  "support_states": [
    "declared",
    "admitted_unsupported",
    "adapter_implemented",
    "verified_supported",
    "deprecated",
    "removed"
  ],
  "credential_requirement_kinds": [
    "none",
    "api_key_secret",
    "local_codex_subscription"
  ],
  "providers": {
    "openai-api": {
      "meaning": "OpenAI API via OpenAI-compatible chat completions.",
      "base_url": "https://api.openai.com",
      "default_model": "gpt-5.5",
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["OPENAI_BASE_URL"],
      "model_env_names": ["OPENAI_MODEL"],
      "credential_env_names": ["OPENAI_API_KEY"],
      "credential_secret_ref": "narada/provider/openai-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/openai-api/api-key",
        "env_names": ["OPENAI_API_KEY"]
      }
    },
    "kimi-api": {
      "meaning": "Kimi/Moonshot API via OpenAI-compatible chat completions.",
      "base_url": "https://api.moonshot.ai",
      "default_model": "kimi-k2.6",
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["KIMI_API_BASE_URL"],
      "model_env_names": ["KIMI_MODEL"],
      "credential_env_names": ["KIMI_API_KEY"],
      "credential_secret_ref": "narada/provider/kimi-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/kimi-api/api-key",
        "env_names": ["KIMI_API_KEY"]
      }
    },
    "kimi-code-api": {
      "meaning": "Kimi Code API via OpenAI-compatible chat completions; uses KIMI_CODE_API_KEY against api.kimi.com/coding/v1.",
      "base_url": "https://api.kimi.com/coding/",
      "default_model": "kimi-k2.6",
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["KIMI_CODE_API_BASE_URL"],
      "model_env_names": ["KIMI_CODE_MODEL"],
      "credential_env_names": ["KIMI_CODE_API_KEY"],
      "credential_secret_ref": "narada/provider/kimi-code-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/kimi-code-api/api-key",
        "env_names": ["KIMI_CODE_API_KEY"]
      }
    },
    "anthropic-api": {
      "meaning": "Anthropic API via the Anthropic Messages API.",
      "base_url": "https://api.anthropic.com",
      "default_model": "claude-sonnet-4.6",
      "adapter_kind": "anthropic-messages",
      "support_state": "verified_supported",
      "base_url_env_names": ["ANTHROPIC_BASE_URL"],
      "model_env_names": ["ANTHROPIC_MODEL"],
      "credential_env_names": ["ANTHROPIC_API_KEY"],
      "credential_secret_ref": "narada/provider/anthropic-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/anthropic-api/api-key",
        "env_names": ["ANTHROPIC_API_KEY"]
      }
    },
    "deepseek-api": {
      "meaning": "DeepSeek API via OpenAI-compatible chat completions.",
      "base_url": "https://api.deepseek.com",
      "default_model": "deepseek-v4-flash",
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["DEEPSEEK_API_BASE_URL"],
      "model_env_names": ["DEEPSEEK_MODEL"],
      "credential_env_names": ["DEEPSEEK_API_KEY"],
      "credential_secret_ref": "narada/provider/deepseek-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/deepseek-api/api-key",
        "env_names": ["DEEPSEEK_API_KEY"]
      }
    },
    "codex-subscription": {
      "meaning": "Local Codex CLI subscription auth via codex mcp-server; no OpenAI API key or API billing path.",
      "base_url": "codex://local-subscription",
      "default_model": "gpt-5.5",
      "adapter_kind": "codex-mcp-server",
      "support_state": "verified_supported",
      "base_url_env_names": [],
      "model_env_names": ["CODEX_MODEL", "NARADA_CODEX_MODEL"],
      "credential_env_names": [],
      "credential_requirement": {
        "kind": "local_codex_subscription"
      }
    }
  }
}
