{
  "schema": "narada.carrier.provider_registry.v1",
  "description": "Authoritative provider metadata for carrier provider resolution, launcher projection, docs, and drift tests.",
  "default_provider": "kimi-code-api",
  "support_states": [
    "declared",
    "admitted_unsupported",
    "adapter_implemented",
    "verified_supported",
    "deprecated",
    "removed"
  ],
  "credential_requirement_kinds": [
    "none",
    "api_key_secret",
    "local_codex_subscription"
  ],
  "providers": {
    "openai-api": {
      "meaning": "OpenAI API via OpenAI-compatible chat completions.",
      "base_url": "https://api.openai.com",
      "default_model": "gpt-5.5",
      "available_models": ["gpt-5.5", "gpt-5.4", "gpt-5.4-mini", "gpt-5.4-nano"],
      "cognition_defaults": {
        "low": { "model": "gpt-5.4-mini", "reasoning_effort": "low" },
        "medium": { "model": "gpt-5.5", "reasoning_effort": "medium" },
        "high": { "model": "gpt-5.5", "reasoning_effort": "high" }
      },
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["OPENAI_BASE_URL"],
      "model_env_names": ["OPENAI_MODEL"],
      "credential_env_names": ["OPENAI_API_KEY"],
      "credential_secret_ref": "narada/provider/openai-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/openai-api/api-key",
        "env_names": ["OPENAI_API_KEY"]
      }
    },
    "kimi-api": {
      "meaning": "Kimi/Moonshot API via OpenAI-compatible chat completions.",
      "base_url": "https://api.moonshot.ai",
      "default_model": "kimi-k2.6",
      "available_models": ["kimi-k2.6", "kimi-k2.7"],
      "cognition_defaults": {
        "low": { "model": "kimi-k2.6", "reasoning_effort": "low" },
        "medium": { "model": "kimi-k2.6", "reasoning_effort": "medium" },
        "high": { "model": "kimi-k2.7", "reasoning_effort": "high" }
      },
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["KIMI_API_BASE_URL"],
      "model_env_names": ["KIMI_MODEL"],
      "credential_env_names": ["KIMI_API_KEY"],
      "credential_secret_ref": "narada/provider/kimi-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/kimi-api/api-key",
        "env_names": ["KIMI_API_KEY"]
      }
    },
    "kimi-code-api": {
      "meaning": "Kimi Code API via OpenAI-compatible chat completions; uses KIMI_CODE_API_KEY against api.kimi.com/coding/v1.",
      "base_url": "https://api.kimi.com/coding/",
      "default_model": "kimi-k2.7",
      "available_models": ["kimi-k2.6", "kimi-k2.7"],
      "cognition_defaults": {
        "low": { "model": "kimi-k2.6", "reasoning_effort": "low" },
        "medium": { "model": "kimi-k2.7", "reasoning_effort": "medium" },
        "high": { "model": "kimi-k2.7", "reasoning_effort": "high" }
      },
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["KIMI_CODE_API_BASE_URL"],
      "model_env_names": ["KIMI_CODE_MODEL"],
      "credential_env_names": ["KIMI_CODE_API_KEY"],
      "credential_secret_ref": "narada/provider/kimi-code-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/kimi-code-api/api-key",
        "env_names": ["KIMI_CODE_API_KEY"]
      }
    },
    "anthropic-api": {
      "meaning": "Anthropic API via the Anthropic Messages API.",
      "base_url": "https://api.anthropic.com",
      "default_model": "claude-sonnet-4.6",
      "available_models": ["claude-sonnet-4.6"],
      "cognition_defaults": {
        "low": { "model": "claude-sonnet-4.6", "reasoning_effort": "low" },
        "medium": { "model": "claude-sonnet-4.6", "reasoning_effort": "medium" },
        "high": { "model": "claude-sonnet-4.6", "reasoning_effort": "high" }
      },
      "adapter_kind": "anthropic-messages",
      "support_state": "verified_supported",
      "base_url_env_names": ["ANTHROPIC_BASE_URL"],
      "model_env_names": ["ANTHROPIC_MODEL"],
      "credential_env_names": ["ANTHROPIC_API_KEY"],
      "credential_secret_ref": "narada/provider/anthropic-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/anthropic-api/api-key",
        "env_names": ["ANTHROPIC_API_KEY"]
      }
    },
    "deepseek-api": {
      "meaning": "DeepSeek API via OpenAI-compatible chat completions.",
      "base_url": "https://api.deepseek.com",
      "default_model": "deepseek-chat",
      "available_models": ["deepseek-chat", "deepseek-reasoner", "deepseek-v3.2-exp", "deepseek-v3.1-terminus"],
      "cognition_defaults": {
        "low": { "model": "deepseek-chat", "reasoning_effort": "low" },
        "medium": { "model": "deepseek-chat", "reasoning_effort": "medium" },
        "high": { "model": "deepseek-reasoner", "reasoning_effort": "high" }
      },
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["DEEPSEEK_API_BASE_URL"],
      "model_env_names": ["DEEPSEEK_MODEL"],
      "credential_env_names": ["DEEPSEEK_API_KEY"],
      "credential_secret_ref": "narada/provider/deepseek-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/deepseek-api/api-key",
        "env_names": ["DEEPSEEK_API_KEY"]
      }
    },
    "glm-api": {
      "meaning": "GLM API via OpenAI-compatible chat completions.",
      "base_url": "https://open.bigmodel.cn/api/paas/v4/",
      "default_model": "GLM-5.2",
      "available_models": ["GLM-5.2", "GLM-5V-Turbo", "GLM-5.1", "GLM-5", "GLM-5-Turbo", "GLM-4.7", "GLM-4.6"],
      "cognition_defaults": {
        "low": { "model": "GLM-5-Turbo", "reasoning_effort": "low" },
        "medium": { "model": "GLM-5.2", "reasoning_effort": "medium" },
        "high": { "model": "GLM-5.2", "reasoning_effort": "high" }
      },
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["GLM_API_BASE_URL"],
      "model_env_names": ["GLM_MODEL"],
      "credential_env_names": ["GLM_API_KEY"],
      "credential_secret_ref": "narada/provider/glm-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/glm-api/api-key",
        "env_names": ["GLM_API_KEY"]
      }
    },
    "openrouter-api": {
      "meaning": "OpenRouter API via OpenAI-compatible chat completions; preserves configured router model identity.",
      "base_url": "https://openrouter.ai/api/",
      "default_model": "openai/gpt-5.5",
      "available_models": ["openai/gpt-5.5"],
      "cognition_defaults": {
        "low": { "model": "openai/gpt-5.5", "reasoning_effort": "low" },
        "medium": { "model": "openai/gpt-5.5", "reasoning_effort": "medium" },
        "high": { "model": "openai/gpt-5.5", "reasoning_effort": "high" }
      },
      "adapter_kind": "openai-compatible-chat-completions",
      "support_state": "verified_supported",
      "base_url_env_names": ["OPENROUTER_BASE_URL", "OPENROUTER_API_BASE_URL"],
      "model_env_names": ["OPENROUTER_MODEL"],
      "credential_env_names": ["OPENROUTER_API_KEY"],
      "credential_secret_ref": "narada/provider/openrouter-api/api-key",
      "credential_requirement": {
        "kind": "api_key_secret",
        "secret_ref": "narada/provider/openrouter-api/api-key",
        "env_names": ["OPENROUTER_API_KEY"]
      }
    },
    "codex-subscription": {
      "meaning": "Local Codex CLI subscription auth via codex mcp-server; no OpenAI API key or API billing path.",
      "base_url": "codex://local-subscription",
      "default_model": "gpt-5.6-sol",
      "default_thinking": "low",
      "model_catalog": {
        "kind": "codex_local_cache",
        "max_age_ms": 86400000
      },
      "available_models": [
        "gpt-5.5",
        "gpt-5.6-sol",
        "gpt-5.6-terra",
        "gpt-5.6-luna",
        "gpt-5.4",
        "gpt-5.4-mini",
        "gpt-5.3-codex-spark"
      ],
      "cognition_defaults": {
        "low": { "model": "gpt-5.6-sol", "reasoning_effort": "low" },
        "medium": { "model": "gpt-5.5", "reasoning_effort": "medium" },
        "high": { "model": "gpt-5.5", "reasoning_effort": "high" }
      },
      "adapter_kind": "codex-mcp-server",
      "support_state": "verified_supported",
      "base_url_env_names": [],
      "model_env_names": ["CODEX_MODEL", "NARADA_CODEX_MODEL"],
      "credential_env_names": [],
      "credential_requirement": {
        "kind": "local_codex_subscription"
      }
    }
