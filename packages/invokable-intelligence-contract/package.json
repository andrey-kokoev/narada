{
  "name": "@narada2/invokable-intelligence-contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "narada": {
    "package_role": "versioned_ontology_and_invocation_contract",
    "surface": "invokable_intelligence",
    "presentation_only": false,
    "authority_owner": "@narada2/cli"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "description": "Versioned contract for Narada's invokable-intelligence ontology",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/invokable-intelligence-contract"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
