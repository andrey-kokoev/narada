{
  "name": "@narada2/cli",
  "version": "0.1.0",
  "description": "CLI for the Narada deterministic state compiler and control plane",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "narada": "./dist/main.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/layers/cli"
  },
  "keywords": [
    "narada",
    "state-compiler",
    "sync",
    "exchange",
    "microsoft-graph",
    "email",
    "automation",
    "cli"
  ],
  "author": "Narada <team@narada.dev>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "@narada2/control-plane": "workspace:*",
    "@narada2/charters": "workspace:*",
    "@narada2/ops-kit": "workspace:*",
    "@narada2/search": "workspace:*"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "memfs": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "homepage": "https://github.com/andrey-kokoev/narada",
  "bugs": {
    "url": "https://github.com/andrey-kokoev/narada/issues"
  }
}
