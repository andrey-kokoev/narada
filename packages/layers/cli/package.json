{
  "name": "@narada2/cli",
  "version": "0.1.0",
  "description": "CLI for the Narada deterministic state compiler and control plane",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "narada": {
    "launch_artifact": {
      "target": "narada-cli",
      "build_script": "build",
      "output_root": "dist",
      "required_outputs": [
        "main.js",
        "index.js",
        "mcp-main.js",
        "ui/workbench.html"
      ]
    }
  },
  "bin": {
    "narada": "./dist/main.js",
    "narada-mcp": "./dist/mcp-main.js"
  },
  "files": [
    "dist/",
    "dist/assets/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/layers/cli"
  },
  "keywords": [
    "narada",
    "state-compiler",
    "sync",
    "exchange",
    "microsoft-graph",
    "email",
    "automation",
    "cli"
  ],
  "author": "Narada <team@narada.dev>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bundleDependencies": [
    "@narada2/agent-context-memory",
    "@narada2/agent-context-mcp",
    "@narada2/agent-identity",
    "@narada2/agent-start",
    "@narada2/agent-runtime-server",
    "@narada2/agent-web-ui",
    "@narada2/nars-client-projection-contract",
    "@narada2/nars-runtime-contract",
    "@narada2/carrier-action-admission",
    "@narada2/carrier-protocol",
    "@narada2/carrier-provider-support",
    "@narada2/carrier-runtime",
    "@narada2/carrier-terminal-projection",
    "@narada2/operator-surface-runtime-contract",
    "@narada2/charters",
    "@narada2/cloudflare-nars-projection",
    "@narada2/cloudflare-site",
    "@narada2/concepts",
    "@narada2/control-plane",
    "@narada2/intent-zones",
    "@narada2/invokable-intelligence-contract",
    "@narada2/invokable-intelligence-management",
    "@narada2/launch-process-ownership",
    "@narada2/linux-site",
    "@narada2/local-history",
    "@narada2/mcp-fabric",
    "@narada2/mcp-transport",
    "@narada2/macos-site",
    "@narada2/nars-session-core",
    "@narada2/operator-console-contract",
    "@narada2/operator-console-ui",
    "@narada2/operator-router",
    "@narada2/ops-kit",
    "@narada2/process-launch-posture",
    "@narada2/search",
    "@narada2/site-config",
    "@narada2/site-common-tools",
    "@narada2/site-continuity",
    "@narada2/site-inbox",
    "@narada2/site-paths",
    "@narada2/site-registry-cloudflare",
    "@narada2/site-registry-contract",
    "@narada2/task-governance-core",
    "@narada2/ui",
    "@narada2/ui-vue",
    "@narada2/sqlite",
    "@narada2/nars-capability-gateway",
    "@narada2/nars-provider-runtime",
    "@narada2/windows-site"
  ],
  "scripts": {
    "prepublishOnly": "node ../../../scripts/assert-publication-admission.js",
    "prebuild": "pnpm --filter @narada2/operator-console-contract build && pnpm --filter @narada2/site-registry-contract build && pnpm --filter @narada2/cloudflare-nars-projection build && pnpm --filter @narada2/agent-start check:result-contract && pnpm --filter @narada2/operator-router build && pnpm --filter @narada2/ui build && pnpm --filter @narada2/operator-console-ui build",
    "build": "tsc && node scripts/write-build-manifest.mjs",
    "pretypecheck": "pnpm --filter @narada2/cloudflare-nars-projection build",
    "typecheck": "tsc --noEmit",
    "test:artifact": "node --test test/lib/launch-artifact.test.mjs",
    "pretest": "pnpm run build && pnpm --filter @narada2/cloudflare-nars-projection build && pnpm --filter @narada2/operator-router build && pnpm --filter @narada2/ui build && pnpm --filter @narada2/operator-console-ui build",
    "test": "node scripts/run-vitest-quiet.mjs run --silent && pnpm run test:realfs",
    "test:launcher": "pnpm run build && node scripts/run-vitest-quiet.mjs run --silent test/commands/carrier-launcher.test.ts test/commands/launcher-workspace-plan.test.ts test/commands/nars.test.ts test/commands/workspace-launch-admission.test.ts && pnpm run test:realfs",
    "test:launcher:focused": "node scripts/run-launcher-focused.mjs",
    "test:publication-boundary": "node scripts/run-publication-boundary-e2e.mjs",
    "test:launcher-acceptance": "pnpm run build && node --import tsx --test --test-concurrency=1 test/integration/operator-launch-journey.test.mjs",
    "test:operator-journey-acceptance": "pnpm run build && pnpm --filter @narada2/agent-web-ui build && node --import tsx --test --test-concurrency=1 test/integration/operator-journey-acceptance-e2e.test.mjs",
    "test:operator-projection-open": "node scripts/run-vitest-quiet.mjs run --silent test/commands/nars.test.ts test/commands/launcher-workspace-plan.test.ts test/lib/browser-render.test.ts test/commands/task-graph.test.ts",
    "test:realfs": "pnpm --filter @narada2/ui build && node --import tsx --test test/integration/*.test.mjs",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@narada2/agent-context-mcp": "workspace:*",
    "@narada2/agent-identity": "workspace:*",
    "@narada2/agent-start": "workspace:*",
    "@narada2/agent-runtime-server": "workspace:*",
    "@clack/prompts": "^0.7.0",
    "@narada2/agent-context-memory": "workspace:*",
    "@narada2/agent-web-ui": "workspace:*",
    "@narada2/nars-client-projection-contract": "workspace:*",
    "@narada2/nars-runtime-contract": "workspace:*",
    "@narada2/carrier-action-admission": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/carrier-provider-support": "workspace:*",
    "@narada2/carrier-runtime": "workspace:*",
    "@narada2/carrier-terminal-projection": "workspace:*",
    "@narada2/operator-surface-runtime-contract": "workspace:*",
    "@narada2/charters": "workspace:*",
    "@narada2/cloudflare-nars-projection": "workspace:*",
    "@narada2/cloudflare-site": "workspace:*",
    "@narada2/concepts": "workspace:*",
    "@narada2/control-plane": "workspace:*",
    "@narada2/intent-zones": "workspace:*",
    "@narada2/invokable-intelligence-contract": "workspace:*",
    "@narada2/invokable-intelligence-management": "workspace:*",
    "@narada2/linux-site": "workspace:*",
    "@narada2/local-history": "workspace:*",
    "@narada2/launch-process-ownership": "workspace:*",
    "@narada2/mcp-fabric": "workspace:*",
    "@narada2/mcp-transport": "workspace:*",
    "@narada2/macos-site": "workspace:*",
    "@narada2/nars-session-core": "workspace:*",
    "@narada2/operator-console-ui": "workspace:*",
    "@narada2/operator-console-contract": "workspace:*",
    "@narada2/operator-router": "workspace:*",
    "@narada2/ops-kit": "workspace:*",
    "@narada2/process-launch-posture": "workspace:*",
    "@narada2/search": "workspace:*",
    "@narada2/site-config": "workspace:*",
    "@narada2/site-common-tools": "workspace:*",
    "@narada2/site-continuity": "workspace:*",
    "@narada2/site-inbox": "workspace:*",
    "@narada2/site-paths": "workspace:*",
    "@narada2/site-registry-cloudflare": "workspace:*",
    "@narada2/site-registry-contract": "workspace:*",
    "@narada2/task-governance-core": "workspace:*",
    "@narada2/ui": "workspace:*",
    "@narada2/ui-vue": "workspace:*",
    "@narada2/sqlite": "workspace:*",
    "@narada2/nars-capability-gateway": "workspace:*",
    "@narada2/nars-provider-runtime": "workspace:*",
    "@narada2/windows-site": "workspace:*",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "lucide-vue-next": "^0.563.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.16.0",
    "tsx": "^4.21.0",
    "vue": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@narada2/invokable-intelligence-registry": "workspace:*",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "memfs": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  },
  "homepage": "https://github.com/andrey-kokoev/narada",
  "bugs": {
    "url": "https://github.com/andrey-kokoev/narada/issues"
  }
}
