{
  "name": "@narada2/control-plane",
  "version": "0.1.0",
  "description": "Deterministic kernel for compiling remote source deltas into local state and durable side-effect intents",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lifecycle": {
      "import": "./dist/lifecycle/index.js",
      "types": "./dist/lifecycle/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "config.schema.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/layers/control-plane"
  },
  "keywords": [
    "narada",
    "state-compiler",
    "sync",
    "exchange",
    "microsoft-graph",
    "email",
    "automation",
    "control-plane"
  ],
  "author": "Narada <team@narada.dev>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && pnpm run generate:config-schema",
    "typecheck": "tsc --noEmit",
    "generate:config-schema": "pnpm exec tsx scripts/generate-config-schema.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "benchmark": "vitest bench --run",
    "benchmark:watch": "vitest bench",
    "benchmark:report": "vitest bench --run --reporter=verbose",
    "profile": "node --inspect --expose-gc ../scripts/profile.ts"
  },
  "dependencies": {
    "@narada2/charters": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.0",
    "fast-check": "^3.15.0",
    "memfs": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "homepage": "https://github.com/andrey-kokoev/narada",
  "bugs": {
    "url": "https://github.com/andrey-kokoev/narada/issues"
  }
}
