{
  "schema": "narada.carrier.protocol_contract.v1",
  "schemas": {
    "input_event": "narada.carrier.input_event.v1",
    "control_input_event": "narada.carrier.control.input_event.v1",
    "session_event": "narada.carrier.session_event.v1",
    "payload_ref": "narada.carrier.payload_ref.v1",
    "payload_policy": "narada.carrier.payload_policy.v1",
    "provider_request_payload": "narada.agent_tui.provider_request_payload.v0",
    "provider_output_payload": "narada.agent_tui.provider_output_payload.v0",
    "turn_terminal_payload": "narada.agent_tui.turn_terminal_payload.v0",
    "session_event_fixture_manifest": "narada.carrier.session_event_fixture_manifest.v1",
    "tool_effect_admission_cases": "narada.carrier.tool_effect_admission_cases.v1"
  },
  "id_prefixes": {
    "input_event": "input_",
    "control_event": "control_",
    "session_event": "session_event_"
  },
  "diagnostic": {
    "levels": ["debug", "info", "warn", "error"],
    "warning_level": "warn",
    "info_level": "info"
  },
  "turn_terminal_status": {
    "completed": ["completed", "completed_after_dispatch", "completed_without_provider"],
    "interrupted": ["interrupted"],
    "failed": ["failed"]
  },
  "terminal_state": {
    "values": ["completed", "interrupted", "failed"]
  },
  "delivery_mode": {
    "values": ["admit_for_current_turn", "admit_after_active_turn"]
  },
  "observer_visibility": {
    "values": ["record_only", "operator_visible", "agent_visible", "conversation_visible"],
    "default": "operator_visible"
  },
  "directive_visibility": {
    "values": ["record_only", "operator_visible", "agent_visible", "conversation_visible"],
    "default": "agent_visible"
  },
  "directive_kind": {
    "values": ["operation_heartbeat"],
    "basic_test_kind": "operation_heartbeat"
  },
  "queue_state": {
    "values": ["queued_for_turn_boundary", "admitted_to_turn", "dropped_by_operator", "abandoned_on_session_end"]
  },
  "input_admission_action": {
    "values": ["admit", "queue", "hold", "reject"]
  },
  "input_hold_action": {
    "values": ["hold", "release", "none"]
  },
  "observer_suppression_reason": {
    "values": ["observer_muted"]
  },
  "payload_ref_reader_tool": {
    "values": ["mcp_payload_read", "mcp_payload_show", "mcp_output_show", "carrier_host_command_output_read"]
  },
  "tool_result_status": {
    "values": ["ok", "denied", "failed"]
  },
  "tool_effect_admission_action": {
    "values": ["admit", "deny"]
  },
  "tool_effect_admission_reason": {
    "values": ["read_only_tool_effect_admitted", "tool_effect_adapter_unconfigured", "tool_effect_admission_required", "unsupported_tool_effect", "tool_effect_authority_denied", "write_tool_effect_admitted"]
  },
  "tool_result_payload": {
    "required": ["tool_name", "status", "duration_ms", "result_summary"],
    "optional": ["admission_action", "admission_reason", "capability_ref", "effect_scope", "authority_ref", "result_ref"],
    "consistency": {
      "paired_fields": [["admission_action", "admission_reason"]],
      "admission_action_status": {
        "deny": ["denied"],
        "admit": ["ok", "failed"]
      },
      "admission_action_reason": {
        "admit": ["read_only_tool_effect_admitted", "write_tool_effect_admitted"],
        "deny": ["tool_effect_adapter_unconfigured", "tool_effect_admission_required", "unsupported_tool_effect", "tool_effect_authority_denied"]
      }
    }
  },
  "input_pipeline_event_kind": {
    "queue": ["input_queued_for_turn_boundary"],
    "admission": [
      "observer_observation_recorded",
      "observer_interjection_proposed",
      "observer_interjection_admitted",
      "observer_interjection_suppressed",
      "directive_receipt_recorded",
      "directive_carrier_accepted_recorded",
      "input_admitted_to_turn"
    ],
    "visible": ["observer_interjection_visible"],
    "hold": ["system_directive_held"],
    "release": ["system_directive_released"]
  },
  "carrier_session_lifecycle_event_kind": {
    "values": ["carrier_session_started", "carrier_session_closed"]
  },
  "carrier_host_command_event_kind": {
    "values": [
      "carrier_host_command_requested",
      "carrier_host_command_admitted",
      "carrier_host_command_rejected",
      "carrier_host_command_started",
      "carrier_host_command_completed",
      "carrier_host_command_failed"
    ]
  }
}
