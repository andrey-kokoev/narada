{
  "name": "@narada2/cloudflare-carrier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/cloudflare-carrier.mjs",
    "./worker": "./src/cloudflare-worker.mjs"
  },
  "scripts": {
    "test": "node --test src/cloudflare-carrier.test.mjs scripts/cloudflare-site-continuity-sync.test.mjs",
    "deploy:check": "node scripts/cloudflare-carrier-deploy-check.mjs",
    "deploy:dry-run": "wrangler deploy --dry-run --config wrangler.toml",
    "deploy:live": "wrangler deploy --config wrangler.toml",
    "d1:migrations:local": "wrangler d1 migrations apply narada-cloudflare-carrier-tasks --local --config wrangler.toml",
    "d1:migrations:remote": "wrangler d1 migrations apply narada-cloudflare-carrier-tasks --remote --config wrangler.toml",
    "smoke:live": "node scripts/cloudflare-carrier-live-smoke.mjs",
    "webhook-delay:shadow-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-shadow-live-smoke.mjs",
    "webhook-delay:observation-primary-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-observation-primary-live-smoke.mjs",
    "webhook-delay:remote-source-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-remote-source-live-smoke.mjs",
    "webhook-delay:direct-source-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-direct-source-live-smoke.mjs",
    "webhook-delay:scheduled-source-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-scheduled-source-live-smoke.mjs",
    "webhook-delay:directive-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-directive-live-smoke.mjs",
    "webhook-delay:directive-delivery-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-directive-delivery-live-smoke.mjs",
    "resident-loop:shadow-smoke:live": "node scripts/cloudflare-carrier-resident-loop-shadow-live-smoke.mjs",
    "task-lifecycle:shadow-smoke:live": "node scripts/cloudflare-carrier-task-lifecycle-shadow-live-smoke.mjs",
    "task-lifecycle:create-smoke:live": "node scripts/cloudflare-carrier-task-lifecycle-create-live-smoke.mjs",
    "task-lifecycle:claim-smoke:live": "node scripts/cloudflare-carrier-task-lifecycle-claim-live-smoke.mjs",
    "task-lifecycle:report-smoke:live": "node scripts/cloudflare-carrier-task-lifecycle-report-live-smoke.mjs",
    "task-lifecycle:changed-file-evidence-smoke:live": "node scripts/cloudflare-carrier-task-lifecycle-changed-file-evidence-live-smoke.mjs",
    "task-lifecycle:finish-smoke:live": "node scripts/cloudflare-carrier-task-lifecycle-finish-live-smoke.mjs",
    "resident-dispatch:smoke:live": "node scripts/cloudflare-carrier-resident-dispatch-live-smoke.mjs",
    "continuity:cloudflare": "node scripts/cloudflare-site-continuity-sync.mjs",
    "ship": "pnpm test && pnpm deploy:check && pnpm deploy:dry-run"
  },
  "dependencies": {
    "@narada2/carrier-command-contract": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/cloudflare-site-registry": "workspace:*",
    "@narada2/site-authority-map": "workspace:*",
    "@narada2/site-continuity": "workspace:*"
  }
}
