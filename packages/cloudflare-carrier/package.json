{
  "name": "@narada2/cloudflare-carrier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/cloudflare-carrier.mjs",
    "./worker": "./src/cloudflare-worker.mjs"
  },
  "scripts": {
    "test": "node --test src/cloudflare-carrier.test.mjs",
    "deploy:check": "node scripts/cloudflare-carrier-deploy-check.mjs",
    "deploy:dry-run": "wrangler deploy --dry-run --config wrangler.toml",
    "deploy:live": "wrangler deploy --config wrangler.toml",
    "d1:migrations:local": "wrangler d1 migrations apply narada-cloudflare-carrier-tasks --local --config wrangler.toml",
    "d1:migrations:remote": "wrangler d1 migrations apply narada-cloudflare-carrier-tasks --remote --config wrangler.toml",
    "smoke:live": "node scripts/cloudflare-carrier-live-smoke.mjs",
    "webhook-delay:shadow-smoke:live": "node scripts/cloudflare-carrier-webhook-delay-shadow-live-smoke.mjs",
    "continuity:cloudflare": "node scripts/cloudflare-site-continuity-sync.mjs",
    "ship": "pnpm test && pnpm deploy:check && pnpm deploy:dry-run"
  },
  "dependencies": {
    "@narada2/carrier-command-contract": "workspace:*",
    "@narada2/carrier-protocol": "workspace:*",
    "@narada2/cloudflare-site-registry": "workspace:*",
    "@narada2/site-authority-map": "workspace:*",
    "@narada2/site-continuity": "workspace:*"
  }
}
