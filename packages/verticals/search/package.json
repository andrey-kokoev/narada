{
  "name": "@narada2/search",
  "version": "0.1.0",
  "description": "Full-text search index for Narada compiled local state",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "narada-search": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/verticals/search"
  },
  "keywords": [
    "narada",
    "state-compiler",
    "sync",
    "search",
    "sqlite",
    "fts5",
    "exchange",
    "microsoft-graph",
    "email"
  ],
  "author": "Narada <team@narada.dev>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "node ../../../scripts/assert-publication-admission.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@narada2/control-plane": "workspace:*",
    "@narada2/sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "homepage": "https://github.com/andrey-kokoev/narada",
  "bugs": {
    "url": "https://github.com/andrey-kokoev/narada/issues"
  }
}
