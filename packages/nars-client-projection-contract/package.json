{
  "name": "@narada2/nars-client-projection-contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "narada": {
    "package_role": "nars_client_projection_contract",
    "owns": [
      "client_projection_capability_sets",
      "client_attach_command_registry",
      "client_projection_verbosity_policy",
      "projection_command_method_aliases",
      "web_operator_command_projection"
    ],
    "does_not_own": [
      "carrier_protocol_schema_validation",
      "runtime_session_execution",
      "browser_ui_rendering"
    ]
  },
  "exports": {
    ".": {
      "types": "./src/nars-client-projection-contract.d.ts",
      "import": "./src/nars-client-projection-contract.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./src/nars-client-projection-contract.d.ts",
  "dependencies": {
    "@narada2/agent-identity": "workspace:*",
    "@narada2/nars-runtime-contract": "workspace:*",
    "@narada2/nars-session-core": "workspace:*"
  },
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false src/nars-client-projection-contract.mjs"
  },
  "description": "NARS client projection capability contracts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-kokoev/narada.git",
    "directory": "packages/nars-client-projection-contract"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
