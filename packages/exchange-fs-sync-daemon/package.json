{
  "name": "exchange-fs-sync-daemon",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "exchange-fs-sync-daemon": "./dist/index.js"
  },
  "scripts": {
    "dev": "rolldown --config --watch",
    "build": "rolldown --config",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "exchange-fs-sync": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "rolldown": "^0.14.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
