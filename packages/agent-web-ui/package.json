{
  "name": "@narada2/agent-web-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "narada": {
    "package_role": "nars_web_client_projection",
    "owns": [
      "browser_event_stream_projection",
      "read_only_session_status_projection",
      "web_attachment_ux",
      "vue_operator_surface_rendering",
      "browser_operator_input_projection"
    ],
    "does_not_own": [
      "runtime_dependency_construction",
      "provider_turn_execution",
      "mcp_fabric_hosting",
      "slash_command_execution"
    ],
    "nars_protocol_methods_source": "@narada2/nars-client-projection-contract#AGENT_WEB_UI_NARS_METHOD_LIST"
  },
  "bin": {
    "narada-agent-web-ui": "./bin/narada-agent-web-ui.mjs"
  },
  "exports": {
    ".": "./src/agent-web-ui.js",
    "./server": "./src/server.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "node ./bin/narada-agent-web-ui.mjs",
    "build": "vite build",
    "test": "node --test test/*.test.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@narada2/nars-client-projection-contract": "workspace:*",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.16.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@narada2/agent-runtime-server": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "postcss": "^8.5.16",
    "type-fest": "^4.41.0",
    "vite": "^8.1.1",
    "vue-tsc": "^2.2.0"
  }
}
