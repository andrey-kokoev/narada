{
  "name": "@narada2/agent-web-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "narada": {
    "package_role": "production_web_ui",
    "production_admission": "allowed",
    "owns": [
      "browser_session_transport",
      "session_store_and_projection",
      "vue_operator_surface_rendering",
      "browser_operator_input_projection"
    ],
    "does_not_own": [
      "runtime_dependency_construction",
      "provider_turn_execution",
      "mcp_fabric_hosting",
      "slash_command_execution"
    ],
    "nars_protocol_methods_source": "@narada2/nars-client-projection-contract",
    "protocol_scope": "local_nars_and_cloudflare_projection"
  },
  "exports": {
    ".": "./src/agent-web-ui.js",
    "./server": "./src/server.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "pnpm --filter @narada2/ui build",
    "build": "vite build",
    "test": "node --test test/agent-web-ui.test.mjs test/agent-web-ui-projection.test.mjs test/agent-web-ui-protocol.test.mjs && pnpm run test:unit",
    "test:unit": "vitest run --config vitest.config.mjs",
    "test:unit:coverage": "vitest run --config vitest.config.mjs --coverage",
    "test:browser": "pnpm run test:e2e",
    "test:live:slash-commands": "pnpm run build && playwright test test/e2e/live-slash-smoke.spec.js",
    "test:live:speech-audio": "pnpm run build && node --test test/agent-web-ui-live-speech-audio-projection-e2e.mjs",
    "test:live:launcher-affordance": "node test/live-launcher-affordance-e2e.mjs",
    "test:all": "pnpm run test && pnpm run test:e2e",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test:e2e": "pnpm run build && playwright test",
    "test:e2e:headed": "pnpm run build && playwright test --headed",
    "test:e2e:ui": "pnpm run build && playwright test --ui",
    "test:browser:cdp": "pnpm run build && node --test test/agent-web-ui-cloudflare-authority-local-surface-artifact-e2e.test.mjs test/agent-web-ui-cloudflare-html-artifact-e2e.test.mjs test/agent-web-ui-local-submit-html-artifact-cloudflare-e2e.test.mjs"
  },
  "dependencies": {
    "@narada2/agent-identity": "workspace:*",
    "@narada2/cloudflare-nars-projection": "workspace:*",
    "@narada2/nars-client-projection-contract": "workspace:*",
    "@narada2/site-paths": "workspace:*",
    "@narada2/ui": "workspace:*",
    "@narada2/ui-vue": "workspace:*",
    "lucide-vue-next": "^0.563.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.16.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@narada2/agent-cli": "workspace:*",
    "@narada2/agent-runtime-server": "workspace:*",
    "@narada2/process-launch-posture": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.1.18",
    "type-fest": "^4.41.0",
    "vite": "^8.1.1",
    "vitest": "^1.6.1",
    "vue-tsc": "^2.2.0"
  }
}
