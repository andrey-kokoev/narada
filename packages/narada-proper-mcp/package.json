{
  "name": "@narada2/narada-proper-mcp",
  "version": "0.1.0",
  "description": "Target-local Narada proper agent-facing MCP surface",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "narada-proper-mcp": "./dist/main.js"
  },
